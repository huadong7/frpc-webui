# Stage 1: Build the web UI
FROM node:22 AS web-builder

COPY web/package.json web/package-lock.json /web/
COPY web/shared/ /web/shared/
COPY web/frpc/ /web/frpc/
WORKDIR /web
RUN npm install
WORKDIR /web/frpc
RUN npm run build

# Stage 2: Build the Go binary
FROM golang:1.25 AS go-builder

COPY . /building
COPY --from=web-builder /web/frpc/dist /building/web/frpc/dist
WORKDIR /building

RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -tags frpc -o bin/frpc ./cmd/frpc

# Stage 3: Runtime
FROM alpine:3

RUN apk add --no-cache tzdata ca-certificates wget

COPY --from=go-builder /building/bin/frpc /usr/bin/frpc

# Data directory for persistent profiles
RUN mkdir -p /data
VOLUME ["/data"]

# Web UI port
EXPOSE 7400

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:7400/healthz || exit 1

ENV FRPC_WEB_ADDR=0.0.0.0
ENV FRPC_WEB_PORT=7400
ENV FRPC_PROFILES_PATH=/data/frpc_profiles.json

ENTRYPOINT ["/usr/bin/frpc", \
  "--profiles-path", "/data/frpc_profiles.json", \
  "--web-addr", "0.0.0.0", \
  "--web-port", "7400"]
